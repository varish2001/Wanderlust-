<% layout("layouts/boilerplate") %>

<div class="row mt-3">
    <h1 class="col-6 offset-3">SignUP for WanderLust</h1>
    <div class="col-6 offset-3">
        <form action="/signup" method="POST" class="needs-validation" novalidate>
            <div class="mb-3"> 
                <label for="username" class="form-label">Username</label>
                <input name="username" id ="username"
                placeholder="Choose a username" 
                type="text" 
                class="form-control"
                required />
                <div class="valid-feedback">Username looks good!</div>
                <div class="invalid-feedback">Please provide a username.</div>
            </div>
            <div class="mb-3"> 
                <label for="email" class="form-label">Email</label>
                <input name="email" id ="email"
                placeholder="Enter your email" 
                type="email" 
                class="form-control"
                required />
                <div class="valid-feedback">Email looks good!</div>
                <div class="invalid-feedback">Please provide a valid email.</div>
            </div>
            <div class="mb-3"> 
                <label for="password" class="form-label">Password</label>
                <input name="password" id ="password"
                placeholder="Choose a password" 
                type="password" 
                class="form-control"
                required />
                <div class="valid-feedback">Password looks good!</div>
                <div class="invalid-feedback">Please provide a password (minimum 6 characters).</div>
            </div>
            <button type="submit" class="btn btn-dark">Sign Up</button>
        </form>
    </div>

</div>