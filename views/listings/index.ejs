<% layout("/layouts/boilerplate") %>
<section class="listings-page py-3">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-4">
        <div>
            <h3 class="mb-1">All Listings</h3>
            <p class="text-muted mb-0">Explore stays curated for your next trip.</p>
        </div>
        <a href="/listings/new" class="btn btn-dark">Create New Listing</a>
    </div>

    <% if (!allListings.length) { %>
        <div class="empty-state text-center py-5">
            <h4 class="mb-2">No listings yet</h4>
            <p class="text-muted mb-3">Start by creating your first stay.</p>
            <a href="/listings/new" class="btn btn-dark">Add Listing</a>
        </div>
    <% } %>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        <% for(let listing of allListings) { %>
            <div class="col">
                <a href="/listings/<%= listing._id %>" class="listing-link">
                    <div class="card col listing-card h-100">
                        <img
                            src="<%= listing.image %>"
                            class="card-img-top listing-image"
                            alt="<%= listing.title %>"
                        >
                        <div class="card-img-overlay listing-overlay"></div>
                        <div class="card-body">
                            <p class="card-text mb-1">
                                <b><%= listing.title %></b>
                            </p>
                            <p class="card-text text-muted mb-0">
                                <%= listing.location %>, <%= listing.country %>
                            </p>
                            <p class="card-text mt-2">
                                &#8377; <%= Number(listing.price || 0).toLocaleString("en-IN") %> / night
                            </p>
                        </div>
                    </div>
                </a>
            </div>
        <% } %>
    </div>
</section>
 

